<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cricket_green_dark"
        android:orientation="vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="14dp" android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tvMatchTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Team A vs Team B"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvTotalOvers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="20 Overs Match"
            android:textColor="#A5D6A7"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Result"
            android:textColor="@color/cricket_gold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:visibility="gone"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- INNINGS 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface_card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvInn1Title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Team A — 0/0 (0.0)"
                        android:textColor="@color/cricket_green_dark"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <!-- Batting label -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="BATTING" android:textColor="@color/cricket_green"
                        android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.12"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:id="@+id/inn1BattingContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                    <TextView
                        android:id="@+id/tvInn1Extras"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Extras: 0"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="10dp"/>

                    <!-- Bowling label -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="BOWLING" android:textColor="@color/cricket_green"
                        android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.12"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:id="@+id/inn1BowlingContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- INNINGS 2 -->
            <LinearLayout
                android:id="@+id/inn2Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/surface_card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvInn2Title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Team B — 0/0 (0.0)"
                            android:textColor="@color/cricket_green_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="BATTING" android:textColor="@color/cricket_green"
                            android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.12"
                            android:layout_marginBottom="4dp"/>

                        <LinearLayout
                            android:id="@+id/inn2BattingContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                        <TextView
                            android:id="@+id/tvInn2Extras"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Extras: 0"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="10dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="BOWLING" android:textColor="@color/cricket_green"
                            android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.12"
                            android:layout_marginBottom="4dp"/>

                        <LinearLayout
                            android:id="@+id/inn2BowlingContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
