<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_bg"
    tools:context=".ui.fragments.matchScoringFragment.MatchScoringFragment">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cricket_green_dark"
        android:orientation="vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="12dp" android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/teamName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Team A — Innings 1"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:letterSpacing="0.04"/>

            <!-- FREE HIT BADGE -->
            <TextView
                android:id="@+id/freeHitBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ FREE HIT"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="#FFD600"
                android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScorecard"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CARD"
                android:textColor="#A5D6A7"
                android:textSize="11sp"
                android:minWidth="0dp"
                android:paddingStart="6dp" android:paddingEnd="6dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/score"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0/0"
            android:textColor="#FFFFFF"
            android:textSize="52sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:layout_marginTop="2dp" android:layout_marginBottom="2dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/oversText" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:text="0.0 ov"
                android:textColor="#A5D6A7" android:textSize="12sp"/>
            <TextView android:id="@+id/crrText" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:text="CRR: 0.00"
                android:textColor="#A5D6A7" android:textSize="12sp"/>
            <TextView android:id="@+id/rrrText" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:text="RRR: —"
                android:textColor="#FFD54F" android:textSize="12sp"/>
            <TextView android:id="@+id/targetText" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:text="Target: —"
                android:textColor="#FFD54F" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- SCROLLABLE BODY -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- This Over -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="THIS OVER" android:textColor="@color/cricket_green"
                        android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.12"/>
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginTop="8dp">
                        <LinearLayout
                            android:id="@+id/ballChipsContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"/>
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Batting Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="BATTING" android:textColor="@color/cricket_green"
                        android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.12"/>
                    <TableLayout
                        android:id="@+id/batsmanTable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:stretchColumns="0">
                        <TableRow>
                            <TextView android:text="Batsman" android:textColor="@color/text_secondary" android:textSize="11sp" android:paddingBottom="4dp"/>
                            <TextView android:text="R" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:minWidth="28dp"/>
                            <TextView android:text="B" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:minWidth="28dp"/>
                            <TextView android:text="4s" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:minWidth="28dp"/>
                            <TextView android:text="6s" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:minWidth="28dp"/>
                            <TextView android:text="SR" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:minWidth="44dp"/>
                        </TableRow>
                        <TableRow>
                            <TextView android:text="Striker*" android:textColor="@color/cricket_green" android:textStyle="bold" android:textSize="14sp" android:paddingTop="4dp"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/text_primary" android:textSize="14sp"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/ball_four" android:textSize="14sp" android:textStyle="bold"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/ball_six" android:textSize="14sp" android:textStyle="bold"/>
                            <TextView android:text="—" android:gravity="center" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        </TableRow>
                        <TableRow>
                            <TextView android:text="Non-Striker" android:textColor="@color/text_secondary" android:textSize="14sp" android:paddingTop="4dp"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:text="—" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                        </TableRow>
                    </TableLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bowling Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="BOWLING" android:textColor="@color/cricket_green"
                        android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.12"/>
                    <TableLayout
                        android:id="@+id/bowlerTable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:stretchColumns="0">
                        <TableRow>
                            <TextView android:text="Bowler" android:textColor="@color/text_secondary" android:textSize="11sp" android:paddingBottom="4dp"/>
                            <TextView android:text="O" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:minWidth="32dp"/>
                            <TextView android:text="M" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:minWidth="28dp"/>
                            <TextView android:text="R" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:minWidth="28dp"/>
                            <TextView android:text="W" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:minWidth="28dp"/>
                            <TextView android:text="ER" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:minWidth="42dp"/>
                        </TableRow>
                        <TableRow>
                            <TextView android:text="Bowler" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp" android:paddingTop="4dp"/>
                            <TextView android:text="0.0" android:gravity="center" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/text_primary" android:textSize="14sp"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/text_primary" android:textSize="14sp"/>
                            <TextView android:text="0" android:gravity="center" android:textColor="@color/ball_wicket" android:textSize="14sp" android:textStyle="bold"/>
                            <TextView android:text="0.00" android:gravity="center" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        </TableRow>
                    </TableLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM PANEL -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_card"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:paddingTop="8dp" android:paddingBottom="10dp">

        <!-- Extras + Wicket row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWicket" style="@style/ChipButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp" android:text="WICKET"
                    android:textColor="@color/ball_wicket" app:strokeColor="@color/ball_wicket" app:strokeWidth="1.5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWide" style="@style/ChipButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp" android:text="WIDE"
                    android:textColor="@color/ball_wide" app:strokeColor="@color/ball_wide" app:strokeWidth="1.5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNb" style="@style/ChipButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp" android:text="NO BALL"
                    android:textColor="@color/ball_noball" app:strokeColor="@color/ball_noball" app:strokeWidth="1.5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBye" style="@style/ChipButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp" android:text="BYE"
                    android:textColor="@color/ball_bye" app:strokeColor="@color/ball_bye" app:strokeWidth="1.5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLegBye" style="@style/ChipButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="LEG BYE"
                    android:textColor="@color/ball_bye" app:strokeColor="@color/ball_bye" app:strokeWidth="1.5dp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Run buttons -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:rowCount="2"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn0" style="@style/RunButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="3dp"
                android:text="·" app:backgroundTint="@color/btn_dot"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1" style="@style/RunButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="3dp"
                android:text="1" app:backgroundTint="@color/btn_single"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn2" style="@style/RunButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="3dp"
                android:text="2" app:backgroundTint="@color/btn_two"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn3" style="@style/RunButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="3dp"
                android:text="3" app:backgroundTint="@color/btn_three"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4" style="@style/RunButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="3dp"
                android:text="4 ▪ FOUR" app:backgroundTint="@color/btn_four"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn5" style="@style/RunButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="3dp"
                android:text="5" app:backgroundTint="@color/btn_five"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn6" style="@style/RunButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="3dp"
                android:text="6 ▪ SIX" app:backgroundTint="@color/btn_six"/>

            <View android:layout_width="0dp" android:layout_height="0dp"
                android:layout_columnWeight="1" android:layout_margin="3dp"/>
        </GridLayout>

        <!-- Swap / Undo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSwap" style="@style/UtilButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                android:text="⇄  SWAP" app:backgroundTint="@color/cricket_green_light"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUndo" style="@style/UtilButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↩  UNDO" app:backgroundTint="@color/cricket_gold"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>